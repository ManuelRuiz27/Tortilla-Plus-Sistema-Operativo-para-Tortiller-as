{
  "name": "@tortilla-plus/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend API de Tortilla Plus V1 Operativa Comercial.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "test:integration": "npm run build && node --test --test-concurrency=1 dist/tests/integration/*.test.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "format": "node -e \"console.log('format pending: no formatter installed in Sprint 0 minimal setup')\"",
    "db:validate": "node scripts/prisma-cli.mjs validate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "node scripts/prisma-cli.mjs migrate deploy",
    "db:seed": "prisma db seed",
    "db:bootstrap:production": "npm run build && node dist/prisma/bootstrap-production.js",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "prisma": "^6.12.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "node dist/prisma/seed.js"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
