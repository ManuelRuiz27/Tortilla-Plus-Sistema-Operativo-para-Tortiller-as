generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                                    String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                  String                      @db.VarChar(160)
  legalName                             String?                     @map("legal_name") @db.VarChar(200)
  taxId                                 String?                     @map("tax_id") @db.VarChar(30)
  contactEmail                          String                      @map("contact_email") @db.VarChar(180)
  contactPhone                          String?                     @map("contact_phone") @db.VarChar(30)
  status                                OrganizationStatus          @default(active)
  createdAt                             DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                             DateTime                    @default(now()) @map("updated_at") @db.Timestamptz(6)
  analyticsSnapshotOrganization         AnalyticsSnapshot[]         @relation("AnalyticsSnapshot_organization")
  auditLogOrganization                  AuditLog[]                  @relation("AuditLog_organization")
  billingInvoiceRequestOrganization     BillingInvoiceRequest[]     @relation("BillingInvoiceRequest_organization")
  billingProfileOrganization            BillingProfile[]            @relation("BillingProfile_organization")
  billingReceiptOrganization            BillingReceipt[]            @relation("BillingReceipt_organization")
  branchProductPriceOrganization        BranchProductPrice[]        @relation("BranchProductPrice_organization")
  branchOrganization                    Branch[]                    @relation("Branch_organization")
  businessUnitOrganization              BusinessUnit[]              @relation("BusinessUnit_organization")
  cashClosingOrganization               CashClosing[]               @relation("CashClosing_organization")
  cashMovementReasonOrganization        CashMovementReason[]        @relation("CashMovementReason_organization")
  cashMovementOrganization              CashMovement[]              @relation("CashMovement_organization")
  cashSessionOrganization               CashSession[]               @relation("CashSession_organization")
  customerBalanceMovementOrganization   CustomerBalanceMovement[]   @relation("CustomerBalanceMovement_organization")
  customerProductPriceOrganization      CustomerProductPrice[]      @relation("CustomerProductPrice_organization")
  customerOrganization                  Customer[]                  @relation("Customer_organization")
  deliveryDriverOrganization            DeliveryDriver[]            @relation("DeliveryDriver_organization")
  deliveryOrderOrganization             DeliveryOrder[]             @relation("DeliveryOrder_organization")
  deliveryPaymentOrganization           DeliveryPayment[]           @relation("DeliveryPayment_organization")
  deliveryReturnOrganization            DeliveryReturn[]            @relation("DeliveryReturn_organization")
  deliveryRouteOrganization             DeliveryRoute[]             @relation("DeliveryRoute_organization")
  deliverySettlementOrganization        DeliverySettlement[]        @relation("DeliverySettlement_organization")
  inventoryMovementOrganization         InventoryMovement[]         @relation("InventoryMovement_organization")
  inventoryStockOrganization            InventoryStock[]            @relation("InventoryStock_organization")
  invoiceOrganization                   Invoice[]                   @relation("Invoice_organization")
  idempotencyRecordOrganization         IdempotencyRecord[]         @relation("IdempotencyRecord_organization")
  paymentProviderConnectionOrganization PaymentProviderConnection[] @relation("PaymentProviderConnection_organization")
  mercadoPagoBranchConfigOrganization   MercadoPagoBranchConfig[]   @relation("MercadoPagoBranchConfig_organization")
  mercadoPagoPosConfigOrganization      MercadoPagoPosConfig[]      @relation("MercadoPagoPosConfig_organization")
  paymentProviderOrganization           PaymentProvider[]           @relation("PaymentProvider_organization")
  paymentTerminalOrganization           PaymentTerminal[]           @relation("PaymentTerminal_organization")
  paymentTerminalBindingOrganization    PosPaymentTerminalBinding[] @relation("PosPaymentTerminalBinding_organization")
  paymentTerminalOrderOrganization      PaymentTerminalOrder[]      @relation("PaymentTerminalOrder_organization")
  paymentTerminalEventOrganization      PaymentTerminalEvent[]      @relation("PaymentTerminalEvent_organization")
  paymentTerminalReferenceOrganization  PaymentTerminalReference[]  @relation("PaymentTerminalReference_organization")
  posDeviceOrganization                 PosDevice[]                 @relation("PosDevice_organization")
  productCategoryOrganization           ProductCategory[]           @relation("ProductCategory_organization")
  productionBatchOrganization           ProductionBatch[]           @relation("ProductionBatch_organization")
  productOrganization                   Product[]                   @relation("Product_organization")
  reconciliationBatchOrganization       ReconciliationBatch[]       @relation("ReconciliationBatch_organization")
  saasPaymentOrganization               SaasPayment[]               @relation("SaasPayment_organization")
  salePaymentOrganization               SalePayment[]               @relation("SalePayment_organization")
  saleReturnOrganization                SaleReturn[]                @relation("SaleReturn_organization")
  saleOrganization                      Sale[]                      @relation("Sale_organization")
  subscriptionOrganization              Subscription[]              @relation("Subscription_organization")
  userRoleOrganization                  UserRole[]                  @relation("UserRole_organization")
  userOrganization                      User[]                      @relation("User_organization")
  wasteRecordOrganization               WasteRecord[]               @relation("WasteRecord_organization")

  @@map("organizations")
}

model BusinessUnit {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String        @map("organization_id") @db.Uuid
  name                 String        @db.VarChar(160)
  tradeName            String?       @map("trade_name") @db.VarChar(200)
  businessType         String?       @map("business_type") @db.VarChar(80)
  status               GenericStatus @default(active)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  branchBusinessUnit   Branch[]      @relation("Branch_businessUnit")
  organization         Organization  @relation("BusinessUnit_organization", fields: [organizationId], references: [id], onUpdate: NoAction)
  customerBusinessUnit Customer[]    @relation("Customer_businessUnit")

  @@map("business_units")
}

model Branch {
  id                             String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                 String                      @map("organization_id") @db.Uuid
  businessUnitId                 String                      @map("business_unit_id") @db.Uuid
  name                           String                      @db.VarChar(160)
  address                        String?
  phone                          String?                     @db.VarChar(30)
  timezone                       String                      @default("America/Mexico_City") @db.VarChar(80)
  status                         GenericStatus               @default(active)
  createdAt                      DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                      DateTime                    @default(now()) @map("updated_at") @db.Timestamptz(6)
  analyticsSnapshotBranch        AnalyticsSnapshot[]         @relation("AnalyticsSnapshot_branch")
  auditLogBranch                 AuditLog[]                  @relation("AuditLog_branch")
  billingInvoiceRequestBranch    BillingInvoiceRequest[]     @relation("BillingInvoiceRequest_branch")
  billingReceiptBranch           BillingReceipt[]            @relation("BillingReceipt_branch")
  branchProductPriceBranch       BranchProductPrice[]        @relation("BranchProductPrice_branch")
  businessUnit                   BusinessUnit                @relation("Branch_businessUnit", fields: [businessUnitId], references: [id], onUpdate: NoAction)
  organization                   Organization                @relation("Branch_organization", fields: [organizationId], references: [id], onUpdate: NoAction)
  cashClosingBranch              CashClosing[]               @relation("CashClosing_branch")
  cashMovementBranch             CashMovement[]              @relation("CashMovement_branch")
  cashSessionBranch              CashSession[]               @relation("CashSession_branch")
  customerProductPriceBranch     CustomerProductPrice[]      @relation("CustomerProductPrice_branch")
  deliveryOrderBranch            DeliveryOrder[]             @relation("DeliveryOrder_branch")
  deliveryPaymentBranch          DeliveryPayment[]           @relation("DeliveryPayment_branch")
  deliveryReturnBranch           DeliveryReturn[]            @relation("DeliveryReturn_branch")
  deliveryRouteBranch            DeliveryRoute[]             @relation("DeliveryRoute_branch")
  deliverySettlementBranch       DeliverySettlement[]        @relation("DeliverySettlement_branch")
  inventoryMovementBranch        InventoryMovement[]         @relation("InventoryMovement_branch")
  inventoryStockBranch           InventoryStock[]            @relation("InventoryStock_branch")
  invoiceBranch                  Invoice[]                   @relation("Invoice_branch")
  paymentTerminalBranch          PaymentTerminal[]           @relation("PaymentTerminal_branch")
  mercadoPagoBranchConfigBranch  MercadoPagoBranchConfig[]   @relation("MercadoPagoBranchConfig_branch")
  mercadoPagoPosConfigBranch     MercadoPagoPosConfig[]      @relation("MercadoPagoPosConfig_branch")
  paymentTerminalBindingBranch   PosPaymentTerminalBinding[] @relation("PosPaymentTerminalBinding_branch")
  paymentTerminalOrderBranch     PaymentTerminalOrder[]      @relation("PaymentTerminalOrder_branch")
  paymentTerminalEventBranch     PaymentTerminalEvent[]      @relation("PaymentTerminalEvent_branch")
  paymentTerminalReferenceBranch PaymentTerminalReference[]  @relation("PaymentTerminalReference_branch")
  posDeviceBranch                PosDevice[]                 @relation("PosDevice_branch")
  productionBatchBranch          ProductionBatch[]           @relation("ProductionBatch_branch")
  reconciliationBatchBranch      ReconciliationBatch[]       @relation("ReconciliationBatch_branch")
  salePaymentBranch              SalePayment[]               @relation("SalePayment_branch")
  saleReturnBranch               SaleReturn[]                @relation("SaleReturn_branch")
  saleBranch                     Sale[]                      @relation("Sale_branch")
  userBranchAssignmentBranch     UserBranchAssignment[]      @relation("UserBranchAssignment_branch")
  wasteRecordBranch              WasteRecord[]               @relation("WasteRecord_branch")

  @@index([organizationId], map: "idx_branches_organization")
  @@map("branches")
}

model Plan {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String         @unique @db.VarChar(60)
  name             String         @db.VarChar(120)
  description      String?
  status           GenericStatus  @default(active)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  planFeaturePlan  PlanFeature[]  @relation("PlanFeature_plan")
  subscriptionPlan Subscription[] @relation("Subscription_plan")

  @@map("plans")
}

model Feature {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String        @unique @db.VarChar(80)
  name               String        @db.VarChar(120)
  description        String?
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  planFeatureFeature PlanFeature[] @relation("PlanFeature_feature")

  @@map("features")
}

model PlanFeature {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId     String   @map("plan_id") @db.Uuid
  featureId  String   @map("feature_id") @db.Uuid
  enabled    Boolean  @default(false)
  limitValue Int?     @map("limit_value")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  feature    Feature  @relation("PlanFeature_feature", fields: [featureId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plan       Plan     @relation("PlanFeature_plan", fields: [planId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([planId, featureId], map: "uq_plan_feature")
  @@map("plan_features")
}

model Subscription {
  id                           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId               String               @map("organization_id") @db.Uuid
  planId                       String               @map("plan_id") @db.Uuid
  status                       SubscriptionStatus   @default(trial)
  billingPeriod                BillingPeriod        @default(monthly) @map("billing_period")
  provider                     SubscriptionProvider @default(mercadopago)
  providerSubscriptionId       String?              @map("provider_subscription_id") @db.VarChar(180)
  startedAt                    DateTime?            @map("started_at") @db.Timestamptz(6)
  currentPeriodStart           DateTime?            @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd             DateTime?            @map("current_period_end") @db.Timestamptz(6)
  graceUntil                   DateTime?            @map("grace_until") @db.Timestamptz(6)
  cancelledAt                  DateTime?            @map("cancelled_at") @db.Timestamptz(6)
  createdAt                    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  saasPaymentSubscription      SaasPayment[]        @relation("SaasPayment_subscription")
  subscriptionItemSubscription SubscriptionItem[]   @relation("SubscriptionItem_subscription")
  organization                 Organization         @relation("Subscription_organization", fields: [organizationId], references: [id], onUpdate: NoAction)
  plan                         Plan                 @relation("Subscription_plan", fields: [planId], references: [id], onUpdate: NoAction)

  @@index([organizationId], map: "idx_subscriptions_organization")
  @@index([status], map: "idx_subscriptions_status")
  @@map("subscriptions")
}

model SubscriptionItem {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscriptionId String               @map("subscription_id") @db.Uuid
  itemType       SubscriptionItemType @map("item_type")
  quantity       Int
  unitPrice      Decimal              @map("unit_price") @db.Decimal(12, 2)
  currency       String               @default("MXN") @db.Char(3)
  status         GenericStatus        @default(active)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  subscription   Subscription         @relation("SubscriptionItem_subscription", fields: [subscriptionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("subscription_items")
}

model SaasPayment {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String               @map("organization_id") @db.Uuid
  subscriptionId    String               @map("subscription_id") @db.Uuid
  provider          SubscriptionProvider @default(mercadopago)
  providerPaymentId String?              @unique @map("provider_payment_id") @db.VarChar(180)
  amount            Decimal              @db.Decimal(12, 2)
  currency          String               @default("MXN") @db.Char(3)
  status            SaasPaymentStatus    @default(pending)
  paidAt            DateTime?            @map("paid_at") @db.Timestamptz(6)
  failedAt          DateTime?            @map("failed_at") @db.Timestamptz(6)
  failureReason     String?              @map("failure_reason")
  rawPayload        Json?                @map("raw_payload")
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization      Organization         @relation("SaasPayment_organization", fields: [organizationId], references: [id], onUpdate: NoAction)
  subscription      Subscription         @relation("SaasPayment_subscription", fields: [subscriptionId], references: [id], onUpdate: NoAction)

  @@map("saas_payments")
}

model MercadopagoWebhookEvent {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId            String    @unique @map("event_id") @db.VarChar(180)
  eventType          String    @map("event_type") @db.VarChar(120)
  providerResourceId String?   @map("provider_resource_id") @db.VarChar(180)
  processed          Boolean   @default(false)
  processedAt        DateTime? @map("processed_at") @db.Timestamptz(6)
  rawPayload         Json      @map("raw_payload")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("mercadopago_webhook_events")
}

model User {
  id                                       String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                           String?                     @map("organization_id") @db.Uuid
  name                                     String                      @db.VarChar(160)
  email                                    String                      @db.VarChar(180)
  phone                                    String?                     @db.VarChar(30)
  passwordHash                             String                      @map("password_hash")
  pinHash                                  String?                     @map("pin_hash")
  status                                   UserStatus                  @default(active)
  lastLoginAt                              DateTime?                   @map("last_login_at") @db.Timestamptz(6)
  createdAt                                DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                DateTime                    @default(now()) @map("updated_at") @db.Timestamptz(6)
  auditLogUser                             AuditLog[]                  @relation("AuditLog_user")
  cashClosingClosedByUser                  CashClosing[]               @relation("CashClosing_closedByUser")
  cashMovementAuthorizedByUser             CashMovement[]              @relation("CashMovement_authorizedByUser")
  cashMovementCancelledByUser              CashMovement[]              @relation("CashMovement_cancelledByUser")
  cashMovementRejectedByUser               CashMovement[]              @relation("CashMovement_rejectedByUser")
  cashMovementRequestedByUser              CashMovement[]              @relation("CashMovement_requestedByUser")
  cashSessionClosedByUser                  CashSession[]               @relation("CashSession_closedByUser")
  cashSessionOpenedByUser                  CashSession[]               @relation("CashSession_openedByUser")
  customerBalanceMovementCreatedByUser     CustomerBalanceMovement[]   @relation("CustomerBalanceMovement_createdByUser")
  deliveryOrderCreatedByUser               DeliveryOrder[]             @relation("DeliveryOrder_createdByUser")
  deliveryOrderPreparedByUser              DeliveryOrder[]             @relation("DeliveryOrder_preparedByUser")
  deliveryReturnReviewedByUser             DeliveryReturn[]            @relation("DeliveryReturn_reviewedByUser")
  deliverySettlementReceivedByUser         DeliverySettlement[]        @relation("DeliverySettlement_receivedByUser")
  inventoryMovementAuthorizedByUser        InventoryMovement[]         @relation("InventoryMovement_authorizedByUser")
  inventoryMovementCreatedByUser           InventoryMovement[]         @relation("InventoryMovement_createdByUser")
  paymentProviderConnectionConnectedByUser PaymentProviderConnection[] @relation("PaymentProviderConnection_connectedByUser")
  paymentTerminalBindingCreatedByUser      PosPaymentTerminalBinding[] @relation("PosPaymentTerminalBinding_createdByUser")
  paymentTerminalOrderCreatedByUser        PaymentTerminalOrder[]      @relation("PaymentTerminalOrder_createdByUser")
  productionBatchClosedByUser              ProductionBatch[]           @relation("ProductionBatch_closedByUser")
  productionBatchCreatedByUser             ProductionBatch[]           @relation("ProductionBatch_createdByUser")
  reconciliationBatchCreatedByUser         ReconciliationBatch[]       @relation("ReconciliationBatch_createdByUser")
  reconciliationBatchReviewedByUser        ReconciliationBatch[]       @relation("ReconciliationBatch_reviewedByUser")
  salePaymentCreatedByUser                 SalePayment[]               @relation("SalePayment_createdByUser")
  saleReturnAuthorizedByUser               SaleReturn[]                @relation("SaleReturn_authorizedByUser")
  saleReturnCreatedByUser                  SaleReturn[]                @relation("SaleReturn_createdByUser")
  saleCancelledByUser                      Sale[]                      @relation("Sale_cancelledByUser")
  saleCreatedByUser                        Sale[]                      @relation("Sale_createdByUser")
  userBranchAssignmentUser                 UserBranchAssignment[]      @relation("UserBranchAssignment_user")
  userRoleUser                             UserRole[]                  @relation("UserRole_user")
  userSessionUser                          UserSession[]               @relation("UserSession_user")
  organization                             Organization?               @relation("User_organization", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  wasteRecordAuthorizedByUser              WasteRecord[]               @relation("WasteRecord_authorizedByUser")
  wasteRecordCreatedByUser                 WasteRecord[]               @relation("WasteRecord_createdByUser")

  @@unique([organizationId, email], map: "uq_users_org_email")
  @@index([organizationId], map: "idx_users_organization")
  @@map("users")
}

model Role {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String           @unique @db.VarChar(80)
  name               String           @db.VarChar(120)
  scope              RoleScope
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  rolePermissionRole RolePermission[] @relation("RolePermission_role")
  userRoleRole       UserRole[]       @relation("UserRole_role")

  @@map("roles")
}

model Permission {
  id                       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                     String           @unique @db.VarChar(100)
  name                     String           @db.VarChar(140)
  description              String?
  createdAt                DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  rolePermissionPermission RolePermission[] @relation("RolePermission_permission")

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  permission   Permission @relation("RolePermission_permission", fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role         Role       @relation("RolePermission_role", fields: [roleId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([roleId, permissionId], map: "uq_role_permission")
  @@map("role_permissions")
}

model UserRole {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  roleId         String        @map("role_id") @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization? @relation("UserRole_organization", fields: [organizationId], references: [id], onDelete: Restrict, onUpdate: NoAction)
  role           Role          @relation("UserRole_role", fields: [roleId], references: [id], onUpdate: NoAction)
  user           User          @relation("UserRole_user", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, roleId, organizationId], map: "uq_user_role_org")
  @@map("user_roles")
}

model UserBranchAssignment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  branch    Branch   @relation("UserBranchAssignment_branch", fields: [branchId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation("UserBranchAssignment_user", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, branchId], map: "uq_user_branch")
  @@map("user_branch_assignments")
}

model UserSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceInfo       String?   @map("device_info")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user             User      @relation("UserSession_user", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_sessions")
}

model PosDevice {
  id                              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                  String                      @map("organization_id") @db.Uuid
  branchId                        String                      @map("branch_id") @db.Uuid
  deviceName                      String                      @map("device_name") @db.VarChar(160)
  deviceCode                      String                      @unique @map("device_code") @db.VarChar(120)
  deviceType                      DeviceType                  @map("device_type")
  status                          DeviceStatus                @default(pending_activation)
  licensed                        Boolean                     @default(false)
  lastSeenAt                      DateTime?                   @map("last_seen_at") @db.Timestamptz(6)
  createdAt                       DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                       DateTime                    @default(now()) @map("updated_at") @db.Timestamptz(6)
  auditLogDevice                  AuditLog[]                  @relation("AuditLog_device")
  cashSessionDevice               CashSession[]               @relation("CashSession_device")
  paymentTerminalBindingPosDevice PosPaymentTerminalBinding[] @relation("PosPaymentTerminalBinding_posDevice")
  paymentTerminalOrderPosDevice   PaymentTerminalOrder[]      @relation("PaymentTerminalOrder_posDevice")
  mercadoPagoPosConfigPosDevice   MercadoPagoPosConfig[]      @relation("MercadoPagoPosConfig_posDevice")
  branch                          Branch                      @relation("PosDevice_branch", fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization                    Organization                @relation("PosDevice_organization", fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  saleDevice                      Sale[]                      @relation("Sale_device")

  @@index([branchId], map: "idx_pos_devices_branch")
  @@map("pos_devices")
}

model ProductCategory {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String        @map("organization_id") @db.Uuid
  name            String        @db.VarChar(140)
  status          GenericStatus @default(active)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  organization    Organization  @relation("ProductCategory_organization", fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productCategory Product[]     @relation("Product_category")

  @@unique([organizationId, name], map: "uq_product_category_org_name")
  @@map("product_categories")
}

model Product {
  id                              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId                  String                 @map("organization_id") @db.Uuid
  categoryId                      String?                @map("category_id") @db.Uuid
  name                            String                 @db.VarChar(160)
  sku                             String?                @db.VarChar(80)
