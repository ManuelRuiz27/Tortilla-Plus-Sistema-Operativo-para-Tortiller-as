  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([relatedEntityType, relatedEntityId], map: "idx_billing_provider_logs_related")
  @@index([provider, operation], map: "idx_billing_provider_logs_provider_operation")
  @@map("billing_provider_logs")
}

model AuditLog {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  branchId       String?       @map("branch_id") @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  deviceId       String?       @map("device_id") @db.Uuid
  action         String        @db.VarChar(120)
  entityType     String        @map("entity_type") @db.VarChar(120)
  entityId       String        @map("entity_id") @db.Uuid
  beforeSnapshot Json?         @map("before_snapshot")
  afterSnapshot  Json?         @map("after_snapshot")
  metadata       Json?
  ipAddress      String?       @map("ip_address") @db.Inet
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  branch         Branch?       @relation("AuditLog_branch", fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  device         PosDevice?    @relation("AuditLog_device", fields: [deviceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization   Organization? @relation("AuditLog_organization", fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user           User?         @relation("AuditLog_user", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([organizationId], map: "idx_audit_logs_org")
  @@map("audit_logs")
}

model AnalyticsSnapshot {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  branchId       String?               @map("branch_id") @db.Uuid
  snapshotDate   DateTime              @map("snapshot_date") @db.Date
  snapshotType   AnalyticsSnapshotType @map("snapshot_type")
