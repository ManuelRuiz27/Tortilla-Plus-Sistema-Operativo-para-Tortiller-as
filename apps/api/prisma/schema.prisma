  branch         Branch?               @relation("AnalyticsSnapshot_branch", fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organization   Organization          @relation("AnalyticsSnapshot_organization", fields: [organizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("analytics_snapshots")
}

