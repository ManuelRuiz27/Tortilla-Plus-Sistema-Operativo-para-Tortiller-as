NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL="postgresql://tortilla_plus:tortilla_plus_dev@localhost:5432/tortilla_plus?schema=public"
DIRECT_URL="postgresql://tortilla_plus:tortilla_plus_dev@localhost:5432/tortilla_plus?schema=public"
JWT_SECRET="change_me_in_local_development"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
BILLING_PROVIDER=mock
FACTURAPI_API_KEY=
FACTURAPI_ENV=sandbox
FACTURAPI_API_BASE_URL=https://www.facturapi.io/v2
FACTURAPI_PUBLIC_ZIP_CODE=64000
FACTURAPI_WEBHOOK_SECRET=
PHYSICAL_INTEGRATIONS_MODE=mock
# Mercado Pago Developers > Tus integraciones > Aplicacion > Credenciales de produccion
# Mercado Pago lo muestra como "Client ID" o "APP_ID"; aqui va como MERCADOPAGO_CLIENT_ID.
MERCADOPAGO_CLIENT_ID=
# Mercado Pago lo muestra como "Client Secret"; aqui va como MERCADOPAGO_CLIENT_SECRET.
MERCADOPAGO_CLIENT_SECRET=
# Debe coincidir exactamente con la Redirect URL registrada en la aplicacion Mercado Pago.
MERCADOPAGO_REDIRECT_URI=http://localhost:3000/api/v1/integrations/mercadopago/oauth/callback
# Mercado Pago OAuth usa normalmente platform_id=mp. Dejalo como mp salvo que Mercado Pago te indique otro valor.
MERCADOPAGO_PLATFORM_ID=
# Opcional. Mercado Pago puede llamarlo Integrator ID en integraciones certificadas/partners.
MERCADOPAGO_INTEGRATOR_ID=
# Clave local para cifrar tokens OAuth en base de datos. No viene de Mercado Pago.
PAYMENT_SECRET_ENCRYPTION_KEY=replace_with_32_plus_random_chars
